// Fixed Vehicle Usage Service - Compatible with Database Schema
// ตัวอย่าง service ที่แก้ไขให้เข้ากันได้กับ database

import { supabase } from '../lib/supabase';

export const vehicleUsageService = {
  // Get daily usage (last 7 days)
  getDailyUsage: async () => {
    const sevenDaysAgo = new Date();
    sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
    sevenDaysAgo.setHours(0, 0, 0, 0);
    
    // Query daily usage view
    const { data, error } = await supabase
      .from('vehicle_usage_daily')
      .select('*')
      .gte('day', sevenDaysAgo.toISOString().split('T')[0])
      .order('day', { ascending: true });
    
    if (error) throw error;
    
    // Transform to chart format
    const labels = (data || []).map(item => {
      const date = new Date(item.day);
      const dayNames = ['อา', 'จ', 'อ', 'พ', 'พฤ', 'ศ', 'ส'];
      return dayNames[date.getDay()];
    });
    
    const usageData = (data || []).map(item => item.active_vehicles || 0);
    
    return {
      labels,
      data: usageData,
    };
  },
};


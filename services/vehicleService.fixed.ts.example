// Fixed Vehicle Service - Compatible with Database Schema
// ตัวอย่าง service ที่แก้ไขให้เข้ากันได้กับ database

import { supabase } from '../lib/supabase';

// Vehicle interface ที่ตรงกับ database
export interface Vehicle {
  id: string;
  plate: string;           // ใช้แทน name
  make?: string;
  model?: string;
  type?: string;
  branch?: string;
  status: 'active' | 'maintenance' | 'idle';  // คำนวณจาก function
  lat?: number;            // Optional (ถ้ามี)
  lng?: number;            // Optional (ถ้ามี)
  fuelLevel?: number;      // คำนวณจาก fuel_records
}

export const vehicleService = {
  // Get all vehicles with status
  getAll: async (): Promise<Vehicle[]> => {
    const { data, error } = await supabase
      .from('vehicles_with_status')
      .select('*');
    
    if (error) throw error;
    
    // Transform to match interface
    return (data || []).map(v => ({
      id: v.id,
      plate: v.plate,
      make: v.make,
      model: v.model,
      type: v.type,
      branch: v.branch,
      status: v.status,
      lat: v.lat,
      lng: v.lng,
      fuelLevel: v.last_fuel_efficiency || undefined,
    }));
  },

  // Get vehicle summary (counts by status)
  getSummary: async () => {
    // Total vehicles
    const { count: total } = await supabase
      .from('vehicles')
      .select('*', { count: 'exact', head: true });
    
    // Active vehicles (in use)
    const { count: active } = await supabase
      .from('vehicle_usage')
      .select('vehicle_id', { count: 'exact', head: true })
      .eq('status', 'in_progress');
    
    // Maintenance vehicles
    const { count: maintenance } = await supabase
      .from('tickets')
      .select('vehicle_id', { count: 'exact', head: true })
      .in('status', ['pending', 'approved_inspector', 'approved_manager', 'ready_for_repair', 'in_progress']);
    
    return {
      total: total || 0,
      active: active || 0,
      maintenance: maintenance || 0,
      idle: (total || 0) - (active || 0) - (maintenance || 0),
    };
  },

  // Get vehicles with locations (for map)
  getLocations: async (): Promise<Vehicle[]> => {
    const { data, error } = await supabase
      .from('vehicles_with_status')
      .select('*')
      .not('lat', 'is', null)
      .not('lng', 'is', null);
    
    if (error) throw error;
    
    return (data || []).map(v => ({
      id: v.id,
      plate: v.plate,
      make: v.make,
      model: v.model,
      status: v.status,
      lat: v.lat,
      lng: v.lng,
      fuelLevel: v.last_fuel_efficiency || undefined,
    }));
  },

  // Get vehicle dashboard data
  getDashboardData: async (vehicleId?: string) => {
    let query = supabase
      .from('vehicle_dashboard')
      .select('*');
    
    if (vehicleId) {
      query = query.eq('id', vehicleId);
    }
    
    const { data, error } = await query;
    
    if (error) throw error;
    return data || [];
  },
};

